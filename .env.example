# σ-Bridge Configuration Template

# Pipeline execution mode: 'classical' (stanza/cltk/transformers) or 'modern'
PIPELINE=classical

# Target language (ISO 639-3 code, e.g. anci1242 for Ancient Greek, lati1261 for Latin)
LANGUAGE=anci1242

# Base URL for the CollateX API service http://x.x.x.x:xxxx
COLLATEX_API_BASE_URL=

# Base URL for the Stemmarest API service http://x.x.x.x:xxxx
STEMMAREST_API_BASE_URL=

# Environment tier: DEV or PROD
ENVIRONMENT=PROD

# System timezone for logs and execution
TIMEZONE=Europe/Zurich

# Directory paths for internal processing
NLP_ANALYSIS_DIR=/tmp/s-bridge/pre_collation
COLLATION_DIR=/tmp/s-bridge/post_collation
DATA_DIR=/app/data

# Application logs configuration (use a writable local path if running outside Docker)
LOG_FILE=/var/log/s-bridge/s-bridge.log
